---
// Interactive "try it" sandbox: hover highlights, click to blur, click again to restore.
// Used on the Click to Censor landing page and in blog posts.
---

<div class="playground__stage">
  <!-- Simulated Browser Dashboard -->
  <div class="browser-mock card">
    <div class="browser-mock__header">
      <div class="browser-mock__dots">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
      <div class="browser-mock__url">https://bank.pixanovalabs.com/dashboard</div>
    </div>

    <div class="browser-mock__body">
      <div class="mock-dashboard">

        <!-- Dashboard Header -->
        <div class="mock-dash__header">
          <div class="mock-profile">
            <div class="mock-avatar censorable" data-censor-type="image">
              <img src="/images/blog/rich-content-showcase/workspace.png" alt="User profile" />
            </div>
            <div class="mock-profile-info">
              <span class="mock-name censorable">Sarah Jenkins</span>
              <span class="mock-email censorable">sarah.j@pixanovalabs.com</span>
            </div>
          </div>
          <span class="mock-badge">Personal Account</span>
        </div>

        <!-- Dashboard Cards Grid -->
        <div class="mock-dash__grid">

          <div class="mock-card">
            <span class="mock-card-title">Available Balance</span>
            <div class="mock-card-val censorable">$12,450.84</div>
            <div class="mock-card-num censorable">•••• •••• •••• 4892</div>
          </div>

          <div class="mock-transactions">
            <span class="mock-card-title">Recent Transactions</span>
            <ul class="mock-trans-list">
              <li class="mock-trans-item">
                <span class="mock-trans-name">Subscription Service</span>
                <strong class="mock-trans-amount censorable">-$14.99</strong>
              </li>
              <li class="mock-trans-item">
                <span class="mock-trans-name">Client Wire Transfer</span>
                <strong class="mock-trans-amount censorable">+$2,500.00</strong>
              </li>
              <li class="mock-trans-item">
                <span class="mock-trans-name">Tech Hardware Store</span>
                <strong class="mock-trans-amount censorable">-$1,249.99</strong>
              </li>
            </ul>
          </div>

        </div>

      </div>
    </div>
  </div>
</div>

<script>
  function initSandbox() {
    const BLUR_RADIUS = 12; // px
    const censorableElements = document.querySelectorAll('.censorable');
    if (!censorableElements.length) return;

    censorableElements.forEach((el) => {
      el.addEventListener('mouseenter', () => {
        if (!el.classList.contains('censored')) el.classList.add('sandbox-hover');
      });
      el.addEventListener('mouseleave', () => el.classList.remove('sandbox-hover'));
      el.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (el.classList.contains('censored')) {
          el.classList.remove('censored');
          el.style.filter = '';
        } else {
          el.classList.remove('sandbox-hover');
          el.classList.add('censored');
          el.style.filter = `blur(${BLUR_RADIUS}px)`;
        }
      });
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSandbox);
  else initSandbox();
</script>

<style>
  .playground__stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 920px;
    margin-inline: auto;
  }

  /* Browser Mock */
  .browser-mock {
    background-color: var(--color-surface);
    box-shadow: 0 10px 40px rgba(28, 43, 51, 0.08);
  }

  .browser-mock__header {
    background-color: var(--color-neutral);
    padding: 12px var(--space-4);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
  }

  .browser-mock__dots {
    display: flex;
    gap: 6px;
    margin-right: var(--space-4);
  }

  .browser-mock__dots .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: rgba(28, 43, 51, 0.15);
  }

  .browser-mock__url {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    flex-grow: 1;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-secondary);
    padding-block: 4px;
    font-family: monospace;
    max-width: 480px;
    margin-inline: auto;
  }

  .browser-mock__body {
    padding: var(--space-8);
  }

  /* Simulated Page Styles */
  .mock-dashboard {
    background-color: var(--color-surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .mock-dash__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-4);
  }

  .mock-profile {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .mock-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-neutral);
    cursor: pointer;
    transition: box-shadow 0.15s ease;
  }

  .mock-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mock-profile-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mock-name {
    font-size: 1.05rem;
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    cursor: pointer;
  }

  .mock-email {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    cursor: pointer;
  }

  .mock-badge {
    background-color: rgba(8, 102, 255, 0.06);
    color: var(--color-tertiary);
    font-size: var(--size-label);
    font-weight: var(--weight-semibold);
    padding: 4px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .mock-dash__grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-6);
  }

  .mock-card {
    background-color: var(--color-neutral);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .mock-card-title {
    font-size: var(--size-label);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    color: var(--color-secondary);
  }

  .mock-card-val {
    font-size: 1.6rem;
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    cursor: pointer;
  }

  .mock-card-num {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    font-family: monospace;
    cursor: pointer;
  }

  .mock-transactions {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mock-trans-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mock-trans-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(28, 43, 51, 0.04);
    padding-bottom: var(--space-2);
  }

  .mock-trans-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .mock-trans-name {
    font-size: var(--size-sm);
    color: var(--color-primary);
  }

  .mock-trans-amount {
    font-size: var(--size-sm);
    color: var(--color-primary);
    cursor: pointer;
  }

  /* Sandbox Interaction helpers */
  .censorable {
    display: inline-block;
    transition: all 0.15s ease;
    border-radius: var(--radius-sm);
  }

  .censorable.sandbox-hover {
    outline: 2px dashed var(--color-tertiary);
    outline-offset: 2px;
    background-color: rgba(8, 102, 255, 0.03);
  }

  .censorable.censored {
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .mock-dash__grid { grid-template-columns: 1fr; }
  }
</style>
