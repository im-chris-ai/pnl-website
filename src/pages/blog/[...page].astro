---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog');
  allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
  return paginate(allPosts, { pageSize: 6 });
}

const { page } = Astro.props;
---

<Layout
  title={`Blog Page ${page.currentPage}`}
  description="Insights, updates, and deep dives from the Pixa Nova Labs team."
>
  <section class="blog-page">
    <div class="container">

      <!-- Header -->
      <header class="blog-page__header">
        <div class="label">Pixa Nova Labs</div>
        <h1>The Blog</h1>
        <p>Insights and updates from our engineering and design team.</p>
      </header>

      <hr class="divider" />

      <!-- Post list -->
      <ol class="post-list">
        {page.data.map((post, i) => (
          <li class="post-list__item">
            <span class="post-list__number label">
              {String((page.currentPage - 1) * 6 + i + 1).padStart(2, '0')}
            </span>
            <div class="post-list__body">
              <time class="post-list__date label" datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-US', {
                  month: 'long', day: 'numeric', year: 'numeric',
                })}
              </time>
              <a class="post-list__title" href={`/blog/${post.id}`}>
                {post.data.title}
              </a>
              <p class="post-list__desc">{post.data.description}</p>
            </div>
            <a href={`/blog/${post.id}`} class="btn btn-secondary post-list__cta">
              Read &rarr;
            </a>
          </li>
        ))}
      </ol>

      <!-- Pagination -->
      <nav class="pagination" aria-label="Blog pagination">
        {page.url.prev
          ? <a href={page.url.prev} class="btn btn-secondary">&larr; Newer</a>
          : <span />
        }
        <span class="label">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next
          ? <a href={page.url.next} class="btn btn-secondary">Older &rarr;</a>
          : <span />
        }
      </nav>

    </div>
  </section>
</Layout>

<style>
  .blog-page {
    padding-block: var(--space-24);
    background-color: var(--color-surface);
  }

  .blog-page__header {
    max-width: 480px;
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .blog-page__header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .blog-page__header p {
    font-size: 1rem;
    color: var(--color-secondary);
    margin: 0;
  }

  /* Post list */
  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-list__item {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  .post-list__number {
    padding-top: 2px;
    color: var(--color-secondary);
  }

  .post-list__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .post-list__date {
    color: var(--color-secondary);
  }

  .post-list__title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    line-height: 1.3;
    transition: color 0.12s ease;
    display: block;
    margin-top: 2px;
  }
  .post-list__title:hover { color: var(--color-tertiary); }

  .post-list__desc {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    margin: 4px 0 0 0;
    line-height: 1.5;
    max-width: 500px;
  }

  .post-list__cta {
    align-self: center;
    padding: 8px 16px;
    font-size: var(--size-sm);
    flex-shrink: 0;
  }

  /* Pagination */
  .pagination {
    margin-top: var(--space-12);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  @media (max-width: 600px) {
    .post-list__item {
      grid-template-columns: 2rem 1fr;
    }
    .post-list__cta {
      grid-column: 2;
      justify-self: start;
      margin-top: var(--space-2);
    }
    .pagination {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
