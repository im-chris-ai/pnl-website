# Cloudflare Workers AI, used for blog cover generation (scripts/cover-gen/generate.mjs).
# Copy this file to .env and fill in real values. Do NOT commit .env.
CF_ACCOUNT_ID=your-account-id
CF_API_TOKEN=your-workers-ai-token

# Optional: override the image model (default: @cf/leonardo/lucid-origin).
# Use models that accept a JSON { prompt } body. Flux 2 models need multipart (unsupported).
# CF_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
