---
// Navigation.astro
const navLinks = [
  { href: '/click-to-censor', label: 'Click to Censor' },
  { href: '/herald',          label: 'Herald' },
  { href: '/blog',            label: 'Blog' },
];
---

<header class="nav">
  <div class="container nav__inner">

    <a href="/" class="nav__brand" aria-label="Pixa Nova Labs, home">
      <img src="/logo.webp" alt="" width="28" height="28" class="nav__logo" />
      <span class="nav__wordmark">Pixa Nova Labs</span>
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      {navLinks.map(l => (
        <a href={l.href} class="nav__link">{l.label}</a>
      ))}
    </nav>

  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  /* Brand */
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .nav__logo {
    display: block;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .nav__wordmark {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* Links */
  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .nav__link {
    font-size: var(--size-sm);
    font-weight: var(--weight-medium);
    color: var(--color-secondary);
    transition: color 0.12s ease;
  }
  .nav__link:hover { color: var(--color-primary); }

  /* CTA */
  .nav__cta {
    padding: 8px 18px;
    font-size: var(--size-sm);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .nav__links { display: none; }
  }
</style>
