---
// Mock spreadsheet for blog screenshots (point: a shared doc/sheet with other people's data).
// Generic, unbranded. `censor` blurs the name, email, and salary cells.
const { censor = false } = Astro.props;
const cols = ['A', 'B', 'C', 'D', 'E'];
const rows = [
  { name: 'Dana Whitfield', email: 'dana@brightpath.io',     dept: 'Engineering', salary: '$142,000', mgr: 'R. Okafor' },
  { name: 'Omar Reyes',     email: 'omar.reyes@nodecraft.com', dept: 'Sales',       salary: '$118,500', mgr: 'J. Park' },
  { name: 'Priya Nair',     email: 'priya@lumen.co',         dept: 'Design',      salary: '$129,000', mgr: 'R. Okafor' },
  { name: 'Tomas Novak',    email: 't.novak@kettle.dev',     dept: 'Engineering', salary: '$155,000', mgr: 'R. Okafor' },
  { name: 'Grace Lin',      email: 'grace.lin@verahealth.com', dept: 'Marketing',   salary: '$108,000', mgr: 'J. Park' },
];
const sens = censor ? 'blur' : '';
---

<div class="sheet mock">
  <div class="sheet__bar">
    <div class="sheet__dots"><span></span><span></span><span></span></div>
    <div class="sheet__url">https://sheets.gridbook.com/d/q3-compensation</div>
  </div>

  <div class="sheet__doc">
    <div class="sheet__name">Q3 Compensation (Confidential)</div>
    <div class="sheet__formula"><span class="sheet__cellref">A1</span><span class="sheet__fx">fx</span><span class="sheet__formula-val">Name</span></div>

    <div class="sheet__grid">
      <table class="sheet__table">
        <thead>
          <tr>
            <th class="sheet__rownum"></th>
            {cols.map((c) => <th class="sheet__colhead">{c}</th>)}
          </tr>
        </thead>
        <tbody>
          <tr class="sheet__headerrow">
            <td class="sheet__rownum">1</td>
            <td>Name</td><td>Email</td><td>Department</td><td>Salary</td><td>Manager</td>
          </tr>
          {rows.map((r, i) => (
            <tr>
              <td class="sheet__rownum">{i + 2}</td>
              <td class={`sens ${sens}`}>{r.name}</td>
              <td class={`sens ${sens}`}>{r.email}</td>
              <td>{r.dept}</td>
              <td class={`sens ${sens}`}>{r.salary}</td>
              <td>{r.mgr}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .sheet {
    font-family: var(--font-sans, system-ui, sans-serif);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(28, 43, 51, 0.10);
    max-width: 980px;
    margin: 0 auto;
  }
  .sheet__bar { display: flex; align-items: center; gap: var(--space-4); background-color: var(--color-neutral); border-bottom: 1px solid var(--color-border); padding: 12px var(--space-4); }
  .sheet__dots { display: flex; gap: 6px; }
  .sheet__dots span { width: 10px; height: 10px; border-radius: 50%; background-color: rgba(28,43,51,0.15); }
  .sheet__url { flex-grow: 1; max-width: 460px; margin-inline: auto; text-align: center; font-family: monospace; font-size: 0.78rem; color: var(--color-secondary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding-block: 4px; }

  .sheet__doc { display: flex; flex-direction: column; }
  .sheet__name { padding: 10px var(--space-5); font-weight: var(--weight-semibold); color: var(--color-primary); border-bottom: 1px solid var(--color-border); }
  .sheet__formula { display: flex; align-items: center; gap: var(--space-3); padding: 6px var(--space-5); border-bottom: 1px solid var(--color-border); background: var(--color-neutral); font-size: var(--size-sm); }
  .sheet__cellref { font-family: monospace; color: var(--color-secondary); min-width: 28px; }
  .sheet__fx { color: var(--color-secondary); font-style: italic; }
  .sheet__formula-val { color: var(--color-primary); }

  .sheet__table { width: 100%; border-collapse: collapse; }
  .sheet__table th, .sheet__table td { border: 1px solid var(--color-border); font-size: var(--size-sm); padding: 8px 10px; text-align: left; color: var(--color-primary); }
  .sheet__colhead, .sheet__rownum { background: var(--color-neutral); color: var(--color-secondary); text-align: center; font-weight: var(--weight-semibold); font-size: var(--size-label); }
  .sheet__rownum { width: 32px; }
  .sheet__headerrow td { font-weight: var(--weight-semibold); background: rgba(8,102,255,0.04); }

  .blur { filter: blur(5px); }
</style>
