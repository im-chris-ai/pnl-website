---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);
---

<Layout
  title="Build with clarity"
  description="Pixa Nova Labs. We build focused, fast, and powerful digital tools for professionals."
>

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__eyebrow label">Pixa Nova Labs</div>
      <h1 class="hero__headline display">
        Tools built for<br /><em>clarity</em>.
      </h1>
      <p class="hero__body">
        We build focused, no-nonsense browser extensions and web apps that solve real problems for developers, creators, and teams. No bloat. No noise.
      </p>
      <div class="hero__actions">
        <a href="#product" class="btn btn-primary">Explore our product</a>
        <a href="/blog" class="btn btn-secondary">Read the blog</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===================== PRODUCT ===================== -->
  <section id="product" class="product-section">
    <div class="container">

      <div class="product-section__header">
        <div class="label">Flagship Product</div>
        <h2>Click to Censor</h2>
        <p>
          A lightweight browser extension that lets you instantly blur, black out, or hide any element on any webpage, in real time. Built for developers who share their screens and creators who record tutorials without exposing sensitive data.
        </p>
      </div>

      <!-- Feature highlights -->
      <ul class="product-features">
        <li class="product-feature card">
          <div class="product-feature__icon">
            <!-- Local / Privacy -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7l-9-5Z" stroke="#0866FF" stroke-width="1.8" stroke-linejoin="round"/>
              <path d="M9 12l2 2 4-4" stroke="#0866FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Runs 100% locally</h3>
          <p>All processing happens in your browser. No data leaves your machine. Ever.</p>
        </li>

        <li class="product-feature card">
          <div class="product-feature__icon">
            <!-- Click / Interact -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18" stroke="#0866FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Click anything to hide</h3>
          <p>Hover to highlight, click to censor. Works on text, images, tables, and more.</p>
        </li>

        <li class="product-feature card">
          <div class="product-feature__icon">
            <!-- Persist / Save -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2Z" stroke="#0866FF" stroke-width="1.8" stroke-linejoin="round"/>
              <path d="M17 21v-8H7v8M7 3v5h8" stroke="#0866FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Persists across reloads</h3>
          <p>Censors are saved per-site by CSS selector and survive page refreshes automatically.</p>
        </li>

        <li class="product-feature card">
          <div class="product-feature__icon">
            <!-- Styles -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="#0866FF" stroke-width="1.8"/>
              <path d="M12 8v4l3 3" stroke="#0866FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Three censor modes</h3>
          <p>Blur, blackout, or fully hide an element. Switch modes on the fly.</p>
        </li>
      </ul>

      <div class="product-section__cta">
        <a href="#" class="btn btn-primary">Add to Chrome, it's free</a>
      </div>

    </div>
  </section>

  <hr class="divider" />

  <!-- ===================== BLOG PREVIEW ===================== -->
  {recentPosts.length > 0 && (
    <section class="blog-preview">
      <div class="container">

        <div class="blog-preview__header">
          <h2>From the lab</h2>
          <a href="/blog" class="btn btn-ghost">
            All posts &rarr;
          </a>
        </div>

        <ol class="blog-preview__list">
          {recentPosts.map((post, i) => (
            <li class="blog-preview__item">
              <span class="blog-preview__index label">{String(i + 1).padStart(2, '0')}</span>
              <div class="blog-preview__content">
                <time class="blog-preview__date label" datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <a href={`/blog/${post.id}`} class="blog-preview__title h3">
                  {post.data.title}
                </a>
                <p class="blog-preview__desc">{post.data.description}</p>
              </div>
              <a href={`/blog/${post.id}`} class="btn btn-secondary blog-preview__read">
                Read
              </a>
            </li>
          ))}
        </ol>

      </div>
    </section>
  )}

</Layout>

<style>
  /* ===================== HERO ===================== */
  .hero {
    padding-block: var(--space-32) var(--space-20);
    background-color: var(--color-surface);
  }

  .hero__inner {
    max-width: 720px;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-5);
  }

  .hero__headline {
    margin-bottom: var(--space-6);
  }

  .hero__body {
    font-size: 1.1rem;
    max-width: 540px;
    margin-bottom: var(--space-8);
    color: var(--color-secondary);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ===================== PRODUCT SECTION ===================== */
  .product-section {
    padding-block: var(--space-24);
    background-color: var(--color-neutral);
  }

  .product-section__header {
    max-width: 540px;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .product-section__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .product-section__header p {
    font-size: 1rem;
    line-height: 1.65;
  }

  /* Feature grid */
  .product-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .product-feature {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background-color: var(--color-surface);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .product-feature:hover {
    box-shadow: 0 4px 20px rgba(28, 43, 51, 0.07);
    transform: translateY(-2px);
  }

  .product-feature__icon {
    width: 40px;
    height: 40px;
    background-color: rgba(8, 102, 255, 0.06);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .product-feature h3 {
    font-size: 1rem;
    font-weight: var(--weight-semibold);
  }

  .product-feature p {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .product-section__cta {
    display: flex;
  }

  /* ===================== BLOG PREVIEW ===================== */
  .blog-preview {
    padding-block: var(--space-24);
    background-color: var(--color-surface);
  }

  .blog-preview__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    gap: var(--space-4);
  }

  .blog-preview__list {
    display: flex;
    flex-direction: column;
  }

  .blog-preview__item {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
    transition: background-color 0.12s ease;
  }

  .blog-preview__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .blog-preview__index {
    padding-top: 3px;
    color: var(--color-secondary);
  }

  .blog-preview__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .blog-preview__date {
    color: var(--color-secondary);
    margin-bottom: var(--space-1);
  }

  .blog-preview__title {
    font-size: 1.1rem;
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    font-family: var(--font-serif);
    line-height: 1.3;
    transition: color 0.12s ease;
  }
  .blog-preview__title:hover { color: var(--color-tertiary); }

  .blog-preview__desc {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    margin: 0;
    margin-top: var(--space-1);
    max-width: 520px;
    line-height: 1.5;
  }

  .blog-preview__read {
    align-self: center;
    padding: 8px 16px;
    font-size: var(--size-sm);
    flex-shrink: 0;
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 640px) {
    .hero { padding-block: var(--space-20) var(--space-12); }

    .blog-preview__item {
      grid-template-columns: 2rem 1fr;
      grid-template-rows: auto auto;
    }
    .blog-preview__read {
      grid-column: 2;
      justify-self: start;
    }
  }
</style>
