                </div>

              </div>

              <span class="phone__home"></span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ===================== HOW IT WORKS ===================== -->
    <section class="steps">
      <div class="container">
        <h2 class="section-title section-title--center">Three steps to a daily habit</h2>
        <ol class="steps__row">
          <li><span class="steps__num">1</span><h3>Add a book</h3><p>Pick a file or type a topic.</p></li>
          <li><span class="steps__num">2</span><h3>Read aloud</h3><p>Tap record and read the page.</p></li>
          <li><span class="steps__num">3</span><h3>Keep the streak</h3><p>See your score, come back tomorrow.</p></li>
        </ol>
      </div>
    </section>

    <!-- ===================== FEATURE 1: NATURAL VOICES ===================== -->
    <section class="frow">
      <div class="container frow__inner">
        <div class="frow__text">
          <div class="eyebrow">Natural voices</div>
          <h2>Hear every page in a real voice</h2>
          <p>A natural voice reads any page aloud so you always have a model to follow. Tap a single word to hear just that word, as many times as you like.</p>
        </div>
        <div class="frow__visual">
          <div class="mock" id="voices-mock">
            <div class="mock__nowplaying">
              <span class="mock__play"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20 6 4"/></svg></span>
              <div class="mock__bars">{bars.map((h, i) => <span style={`height:${h}px; animation-delay:${((i % 9) * 0.1).toFixed(2)}s`}></span>)}</div>
            </div>
            <div class="mock__chips">
              <span class="chip chip--on">Heart</span>
              <span class="chip">George</span>
              <span class="chip">Bella</span>
              <span class="chip">Liam</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURE 2: SCORING ===================== -->
    <section class="frow frow--alt frow--reverse">
      <div class="container frow__inner">
        <div class="frow__text">
          <div class="eyebrow">Read and get scored</div>
          <h2>Know exactly how you did</h2>
          <p>Read the page out loud and Herald scores it gently. The words you said clearly turn green, and the ones to work on turn red, so you always know what to practice next.</p>
        </div>
        <div class="frow__visual">
          <div class="mock" id="score-mock">
            <p class="mock__para" id="score-para">
              <span class="sw">Reading</span> <span class="sw">out</span> <span class="sw">loud</span> <span class="sw">every</span> <span class="sw">single</span> <span class="sw">day</span> <span class="sw">is</span> <span class="sw">how</span> <span class="sw">real,</span> <span class="sw">steady</span> <span class="sw">progress</span> <span class="sw">happens.</span>
            </p>
            <div class="mock__bigscore"><span class="num"><span id="score-mock-num">0</span>%</span><span class="lbl">Best score</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURE: WORD LOOKUP ===================== -->
    <section class="frow">
      <div class="container frow__inner">
        <div class="frow__text">
          <div class="eyebrow">Word lookup</div>
          <h2>Tap a word, get its meaning</h2>
          <p>Tap any word to hear it and see a simple respelling, a short meaning, and a few similar words, right there on the page.</p>
        </div>
        <div class="frow__visual">
          <div class="mock">
            <div class="lookup" id="lookup-card">
              <div class="lookup__head">
                <span class="lookup__word" id="lookup-word">proximity</span>
                <span class="lookup__speak"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></span>
              </div>
              <div class="lookup__resp" id="lookup-resp">prok·sim·i·tee</div>
              <p class="lookup__def" id="lookup-def">The state of being near to something.</p>
              <div class="lookup__syns">
                <span class="syn" id="lookup-syn1">nearness</span>
                <span class="syn" id="lookup-syn2">closeness</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURE: GENERATE ===================== -->
    <section class="frow frow--alt frow--reverse">
      <div class="container frow__inner">
        <div class="frow__text">
          <div class="eyebrow">Generate a book</div>
          <h2>Never run out of things to read</h2>
          <p>No book on hand? Type any topic and Herald writes a short, readable passage for you to practice with, ready in seconds.</p>
        </div>
        <div class="frow__visual">
          <div class="mock" id="gen-mock">
            <div class="mock__field">
              <span class="gen-input"><span id="gen-topic">The history of coffee</span><span class="gen-caret"></span></span>
              <span class="mock__gen">Generate</span>
            </div>
            <div class="mock__page">
              <strong id="gen-title">The History of Coffee</strong>
              <span class="gen-line" style="width:100%"></span>
              <span class="gen-line" style="width:100%"></span>
              <span class="gen-line" style="width:78%"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURE: UPLOAD ===================== -->
    <section class="frow">
      <div class="container frow__inner">
        <div class="frow__text">
          <div class="eyebrow">Upload a document</div>
          <h2>Bring your own reading</h2>
          <p>Have something you want to practice with? Upload a text or Markdown file and Herald turns it into clean, readable pages.</p>
        </div>
        <div class="frow__visual">
          <div class="mock">
            <div class="upload">
              <div class="upload__file" id="upload-file">
                <span class="upload__doc"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg></span>
                <div class="upload__meta">
                  <strong id="upload-name">the-lighthouse.md</strong>
                  <span id="upload-sub">12 readable pages</span>
                </div>
                <span class="upload__check"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>
              </div>
              <div class="upload__preview">
                <strong id="upload-title">The Lighthouse</strong>
                <span class="upload__line" style="width:100%"></span>
                <span class="upload__line" style="width:100%"></span>
                <span class="upload__line" style="width:72%"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURE: PROGRESS ===================== -->
    <section class="frow frow--alt frow--reverse">
      <div class="container frow__inner">
        <div class="frow__text">
          <div class="eyebrow">Your progress</div>
          <h2>Watch the habit grow</h2>
          <p>Build a streak, track your accuracy over time, and keep all of it when you sign in, even on a brand-new phone.</p>
        </div>
        <div class="frow__visual">
          <div class="mock">
            <div class="mock__stats">
              <div><strong><span id="cal-streak">7</span></strong>day streak</div>
              <div><strong><span id="cal-acc">94</span>%</strong>accuracy</div>
            </div>
            <div class="cal">
              <div class="cal__month">June</div>
              <div class="cal__grid">
                {dow.map((d) => <span class="cal__dow">{d}</span>)}
                {calCells.map((d) => d === null
                  ? <span class="cal__day cal__day--blank"></span>
                  : <span class="cal__day" data-lvl={levels[d] || 0}>{d}</span>)}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CTA ===================== -->
    <section class="cta">
      <div class="container cta__inner">
        <h2>Start your daily reading habit.</h2>
        <span class="btn-soon btn-soon--light">Coming soon to Google Play</span>
        <a href="/herald/privacy" class="cta__policy">Privacy policy</a>
      </div>
    </section>

  </div>
</Layout>

<!-- ===================== PREVIEW SCRIPT ===================== -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const wait = (ms) => new Promise((r) => setTimeout(r, ms));
    const countUp = (el, target, dur) => new Promise((resolve) => {
      const start = performance.now();
      (function tick(now) {
        const p = Math.min(1, (now - start) / dur);
        el.textContent = String(Math.round(p * target));
        if (p < 1) requestAnimationFrame(tick);
        else resolve();
      })(performance.now());
    });

    // ---- Phone hero: loop home screen -> reader -> record -> score -> back ----
    (function () {
      const track = document.getElementById('screen-track');
      const para = document.getElementById('reader-para');
      const scoreNum = document.getElementById('score-num');
      const recBtn = document.getElementById('rec-btn');
      if (!track || !para || !scoreNum || !recBtn) return;
      const label = recBtn.querySelector('.rbtn__label');
      const scoreBlock = document.getElementById('score-block');
      const waveBlock = document.getElementById('wave-block');
      const words = Array.from(para.querySelectorAll('.w'));
      const missIndex = words.findIndex((w) => /curtain/i.test(w.textContent));
      const STEP = 90;
      function setRecording(on) {
        recBtn.classList.toggle('rbtn--active', on);
        if (label) label.textContent = on ? 'Recording' : 'Record';
        if (scoreBlock) scoreBlock.classList.toggle('hide', on);
        if (waveBlock) waveBlock.classList.toggle('show', on);
      }
      (async function loop() {
        while (true) {
          // home screen
          track.classList.remove('show-reader');
          words.forEach((w) => w.classList.remove('matched', 'missed'));
          scoreNum.textContent = '0';
          setRecording(false);
          await wait(3200);
          // slide to the reading screen and record
          track.classList.add('show-reader');
          await wait(700);
          setRecording(true);
          await wait(1800);
          setRecording(false);
          await wait(400);
          words.forEach((w, i) => setTimeout(() => w.classList.add(i === missIndex ? 'missed' : 'matched'), STEP * i));
          await countUp(scoreNum, 92, STEP * words.length);
          await wait(2400);
        }
      })();
    })();

    // ---- Voices: cycle the selected voice ----
    (function () {
      const chips = Array.from(document.querySelectorAll('#voices-mock .chip'));
      if (!chips.length) return;
      let i = 0;
      setInterval(() => {
        chips.forEach((c) => c.classList.remove('chip--on'));
        i = (i + 1) % chips.length;
        chips[i].classList.add('chip--on');
      }, 1700);
    })();

    // ---- Scoring: two mistakes, then one, looping ----
    (function () {
      const para = document.getElementById('score-para');
      const scoreNum = document.getElementById('score-mock-num');
      if (!para || !scoreNum) return;
      const words = Array.from(para.querySelectorAll('.sw'));
      const total = words.length;
      const missSets = [[9, 11], [9]];
      const STEP = 95;
      let s = 0;
      (async function loop() {
        while (true) {
          words.forEach((w) => w.classList.remove('g', 'r'));
          scoreNum.textContent = '0';
          await wait(700);
          const miss = missSets[s];
          words.forEach((w, i) => setTimeout(() => w.classList.add(miss.includes(i) ? 'r' : 'g'), STEP * i));
          await countUp(scoreNum, Math.round(((total - miss.length) / total) * 100), STEP * total);
          await wait(2400);
          s = (s + 1) % missSets.length;
        }
      })();
    })();

    // ---- Generate: type a topic, build a page, cycle topics ----
    (function () {
      const topicEl = document.getElementById('gen-topic');
      const titleEl = document.getElementById('gen-title');
      const mock = document.getElementById('gen-mock');
      if (!topicEl || !titleEl || !mock) return;
      const lines = Array.from(mock.querySelectorAll('.gen-line'));
      const widths = ['100%', '100%', '78%'];
      const topics = [
        { q: 'The history of coffee', title: 'The History of Coffee' },
        { q: 'How volcanoes erupt', title: 'How Volcanoes Erupt' },
        { q: 'The life of honeybees', title: 'The Life of Honeybees' },
      ];
      let t = 0;
      (async function loop() {
        while (true) {
          const topic = topics[t];
          topicEl.textContent = '';
          await wait(500);
          for (let c = 0; c < topic.q.length; c++) {
            topicEl.textContent += topic.q[c];
            await wait(55);
          }
          await wait(550);
          titleEl.textContent = topic.title;
          lines.forEach((l) => { l.style.width = '0%'; });
          await wait(60);
          lines.forEach((l, i) => { l.style.width = widths[i]; });
          await wait(2600);
          t = (t + 1) % topics.length;
        }
      })();
    })();

    // ---- Word lookup: cycle through a few words ----
    (function () {
      const card = document.getElementById('lookup-card');
      const wordEl = document.getElementById('lookup-word');
      const respEl = document.getElementById('lookup-resp');
      const defEl = document.getElementById('lookup-def');
      const syn1 = document.getElementById('lookup-syn1');
      const syn2 = document.getElementById('lookup-syn2');
      if (!card || !wordEl) return;
      const items = [
        { word: 'proximity', resp: 'prok·sim·i·tee', def: 'The state of being near to something.', syns: ['nearness', 'closeness'] },
        { word: 'horizon', resp: 'huh·ry·zuhn', def: 'The line where the earth seems to meet the sky.', syns: ['skyline', 'distance'] },
        { word: 'gratitude', resp: 'grat·i·tood', def: 'A warm feeling of being thankful.', syns: ['thankfulness', 'appreciation'] },
      ];
      let i = 0;
      (async function loop() {
        while (true) {
          await wait(3000);
          i = (i + 1) % items.length;
          card.classList.add('fade');
          await wait(250);
          const it = items[i];
          wordEl.textContent = it.word;
          respEl.textContent = it.resp;
          defEl.textContent = it.def;
          syn1.textContent = it.syns[0];
          syn2.textContent = it.syns[1];
          card.classList.remove('fade');
        }
      })();
    })();

    // ---- Upload: a file drops in, then cycles ----
    (function () {
      const fileEl = document.getElementById('upload-file');
      const nameEl = document.getElementById('upload-name');
      const subEl = document.getElementById('upload-sub');
      if (!fileEl || !nameEl || !subEl) return;
      const titleEl = document.getElementById('upload-title');
      const files = [
        { name: 'the-lighthouse.md', sub: '12 readable pages', title: 'The Lighthouse' },
        { name: 'morning-notes.txt', sub: '6 readable pages', title: 'Morning Notes' },
        { name: 'chapter-one.md', sub: '9 readable pages', title: 'Chapter One' },
      ];
      let i = 0;
      (async function loop() {
        while (true) {
          nameEl.textContent = files[i].name;
          subEl.textContent = files[i].sub;
          if (titleEl) titleEl.textContent = files[i].title;
          await wait(700);
          fileEl.classList.add('show');
          await wait(2800);
          fileEl.classList.remove('show');
          await wait(700);
          i = (i + 1) % files.length;
        }
      })();
    })();

    // ---- Progress calendar: cascade-fill the month + count the stats ----
    (function () {
      const days = Array.from(document.querySelectorAll('.cal__grid .cal__day[data-lvl]'));
      const streakEl = document.getElementById('cal-streak');
      const accEl = document.getElementById('cal-acc');
      if (!days.length || !streakEl || !accEl) return;
      (async function loop() {
        while (true) {
          days.forEach((d) => { d.className = 'cal__day'; });
          streakEl.textContent = '0';
          accEl.textContent = '0';
          await wait(800);
          days.forEach((d, i) => setTimeout(() => {
            const lvl = d.getAttribute('data-lvl');
            if (lvl && lvl !== '0') d.classList.add('lvl-' + lvl);
          }, i * 45));
          const dur = days.length * 45;
          countUp(streakEl, 7, dur);
          await countUp(accEl, 94, dur);
          await wait(2600);
        }
      })();
    })();
  });
</script>

