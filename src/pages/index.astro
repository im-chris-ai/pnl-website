---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);
---

<Layout
  title="Build with clarity"
  description="Pixa Nova Labs. We build focused, fast, and powerful digital tools for professionals."
>

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__eyebrow label">Pixa Nova Labs</div>
      <h1 class="hero__headline display">
        Tools built for<br /><em>clarity</em>.
      </h1>
      <p class="hero__body">
        We build focused, no-nonsense browser extensions and web apps that solve real problems for developers, creators, and teams. No bloat. No noise.
      </p>
      <div class="hero__actions">
        <a href="#product" class="btn btn-primary">Explore our product</a>
        <a href="/blog" class="btn btn-secondary">Read the blog</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===================== OUR APPS ===================== -->
  <section id="product" class="apps-section">
    <div class="container">
      <div class="apps-section__header">
        <div class="label">Our apps</div>
        <h2>Focused tools, no bloat</h2>
        <p>Each app does one job, and does it well. Built for developers, creators, and teams who want power without the noise.</p>
      </div>
      <ul class="apps-grid">
        <li>
          <a href="/click-to-censor" class="app-card card">
            <div class="app-card__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0866FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10.585 10.587a2 2 0 0 0 2.829 2.828" />
                <path d="M16.681 16.673A8.717 8.717 0 0 1 12 18c-3.6 0-6.6-2-9-6 1.272-2.12 2.712-3.678 4.32-4.674m2.86-1.146A9.055 9.055 0 0 1 12 6c3.6 0 6.6 2 9 6-.666 1.11-1.379 2.067-2.138 2.87" />
                <path d="M3 3l18 18" />
              </svg>
            </div>
            <h3>Click to Censor</h3>
            <p>Blur, black out, or hide anything on any webpage. Share your screen without leaks.</p>
            <span class="app-card__link">Learn more &rarr;</span>
          </a>
        </li>
        <li>
          <a href="/herald" class="app-card card">
            <div class="app-card__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0866FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 8a5 5 0 0 1 0 8" />
                <path d="M17.7 5a9 9 0 0 1 0 14" />
                <path d="M6 15H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1h2l3.5-4.5A.8.8 0 0 1 11 5v14a.8.8 0 0 1-1.5.5L6 15" />
              </svg>
            </div>
            <h3>Herald</h3>
            <p>A read-aloud app that scores your pronunciation and builds a daily speaking habit.</p>
            <span class="app-card__link">Learn more &rarr;</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <hr class="divider" />

  <!-- ===================== BLOG PREVIEW ===================== -->
  {recentPosts.length > 0 && (
    <section class="blog-preview">
      <div class="container">

        <div class="blog-preview__header">
          <h2>From the lab</h2>
          <a href="/blog" class="btn btn-ghost">
            All posts &rarr;
          </a>
        </div>

        <ol class="blog-preview__list">
          {recentPosts.map((post, i) => (
            <li class="blog-preview__item">
              <span class="blog-preview__index label">{String(i + 1).padStart(2, '0')}</span>
              <div class="blog-preview__content">
                <time class="blog-preview__date label" datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <a href={`/blog/${post.id}`} class="blog-preview__title h3">
                  {post.data.title}
                </a>
                <p class="blog-preview__desc">{post.data.description}</p>
              </div>
              <a href={`/blog/${post.id}`} class="btn btn-secondary blog-preview__read">
                Read
              </a>
            </li>
          ))}
        </ol>

      </div>
    </section>
  )}

</Layout>

<style>
  /* ===================== HERO ===================== */
  .hero {
    padding-block: var(--space-32) var(--space-20);
    background-color: var(--color-surface);
  }

  .hero__inner {
    max-width: 720px;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-5);
  }

  .hero__headline {
    margin-bottom: var(--space-6);
  }

  .hero__body {
    font-size: 1.1rem;
    max-width: 540px;
    margin-bottom: var(--space-8);
    color: var(--color-secondary);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ===================== OUR APPS ===================== */
  .apps-section {
    padding-block: var(--space-24);
    background-color: var(--color-neutral);
  }

  .apps-section__header {
    max-width: 540px;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .apps-section__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .apps-section__header p {
    font-size: 1rem;
    line-height: 1.65;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }

  .app-card {
    height: 100%;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background-color: var(--color-surface);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .app-card:hover {
    box-shadow: 0 4px 20px rgba(28, 43, 51, 0.07);
    transform: translateY(-2px);
  }

  .app-card__icon {
    width: 40px;
    height: 40px;
    background-color: rgba(8, 102, 255, 0.06);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .app-card h3 {
    font-size: 1rem;
    font-weight: var(--weight-semibold);
  }

  .app-card p {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .app-card__link {
    font-size: var(--size-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-tertiary);
    margin-top: auto;
    padding-top: var(--space-2);
  }

  /* ===================== BLOG PREVIEW ===================== */
  .blog-preview {
    padding-block: var(--space-24);
    background-color: var(--color-surface);
  }

  .blog-preview__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    gap: var(--space-4);
  }

  .blog-preview__list {
    display: flex;
    flex-direction: column;
  }

  .blog-preview__item {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
    transition: background-color 0.12s ease;
  }

  .blog-preview__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .blog-preview__index {
    padding-top: 3px;
    color: var(--color-secondary);
  }

  .blog-preview__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .blog-preview__date {
    color: var(--color-secondary);
    margin-bottom: var(--space-1);
  }

  .blog-preview__title {
    font-size: 1.1rem;
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    font-family: var(--font-serif);
    line-height: 1.3;
    transition: color 0.12s ease;
  }
  .blog-preview__title:hover { color: var(--color-tertiary); }

  .blog-preview__desc {
    font-size: var(--size-sm);
    color: var(--color-secondary);
    margin: 0;
    margin-top: var(--space-1);
    max-width: 520px;
    line-height: 1.5;
  }

  .blog-preview__read {
    align-self: center;
    padding: 8px 16px;
    font-size: var(--size-sm);
    flex-shrink: 0;
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 640px) {
    .hero { padding-block: var(--space-20) var(--space-12); }

    .blog-preview__item {
      grid-template-columns: 2rem 1fr;
      grid-template-rows: auto auto;
    }
    .blog-preview__read {
      grid-column: 2;
      justify-self: start;
    }
  }
</style>
