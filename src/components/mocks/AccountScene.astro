---
// Mock personal account / profile settings page for blog screenshots (point: your own
// email + phone number on screen). Generic, unbranded. `censor` renders the "after" state
// with email and phone hidden, mirroring the extension (blur = filter, blackout = solid box).
const { censor = false } = Astro.props;
---

<div class="acct mock">
  <!-- Browser chrome -->
  <div class="acct__bar">
    <div class="acct__dots"><span></span><span></span><span></span></div>
    <div class="acct__url">https://app.workspace.com/account/profile</div>
  </div>

  <div class="acct__app">
    <!-- Sidebar -->
    <aside class="acct__side">
      <div class="acct__brand"><span class="acct__logo"></span> Workspace</div>
      <nav class="acct__nav">
        <span class="acct__navitem">General</span>
        <span class="acct__navitem acct__navitem--active">Profile</span>
        <span class="acct__navitem">Security</span>
        <span class="acct__navitem">Billing</span>
        <span class="acct__navitem">Notifications</span>
      </nav>
    </aside>

    <!-- Main -->
    <main class="acct__main">
      <header class="acct__head">
        <div class="acct__id">
          <span class="acct__avatar"></span>
          <div>
            <h1 class="acct__title">Sarah Jenkins</h1>
            <p class="acct__sub">Personal account</p>
          </div>
        </div>
        <span class="acct__btn">Edit profile</span>
      </header>

      <!-- Contact details card -->
      <section class="acct__card">
        <span class="acct__card-title">Contact details</span>
        <dl class="acct__fields">
          <div class="acct__field">
            <dt>Full name</dt>
            <dd>Sarah Jenkins</dd>
          </div>
          <div class="acct__field">
            <dt>Email address</dt>
            <dd class={`sens ${censor ? 'blur' : ''}`}>sarah.jenkins@gmail.com</dd>
          </div>
          <div class="acct__field">
            <dt>Phone number</dt>
            <dd class={`sens ${censor ? 'blur' : ''}`}>+1 (415) 555-0182</dd>
          </div>
          <div class="acct__field">
            <dt>Address</dt>
            <dd>2140 Larkin Street, San Francisco, CA</dd>
          </div>
        </dl>
      </section>

      <!-- Plan strip -->
      <section class="acct__plan">
        <div>
          <span class="acct__plan-name">Pro plan</span>
          <span class="acct__plan-meta">Renews Aug 1, card ending 4417</span>
        </div>
        <span class="acct__plan-pill">Active</span>
      </section>
    </main>
  </div>
</div>

<style>
  .acct {
    font-family: var(--font-sans, system-ui, sans-serif);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(28, 43, 51, 0.10);
    max-width: 980px;
    margin: 0 auto;
  }

  .acct__bar {
    display: flex; align-items: center; gap: var(--space-4);
    background-color: var(--color-neutral);
    border-bottom: 1px solid var(--color-border);
    padding: 12px var(--space-4);
  }
  .acct__dots { display: flex; gap: 6px; }
  .acct__dots span { width: 10px; height: 10px; border-radius: 50%; background-color: rgba(28,43,51,0.15); }
  .acct__url {
    flex-grow: 1; max-width: 460px; margin-inline: auto;
    text-align: center; font-family: monospace; font-size: 0.78rem;
    color: var(--color-secondary); background-color: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding-block: 4px;
  }

  .acct__app { display: grid; grid-template-columns: 200px 1fr; }

  .acct__side {
    background-color: var(--color-neutral);
    border-right: 1px solid var(--color-border);
    padding: var(--space-6) var(--space-4);
    display: flex; flex-direction: column; gap: var(--space-6);
  }
  .acct__brand { display: flex; align-items: center; gap: 8px; font-weight: var(--weight-bold); color: var(--color-primary); font-size: 1.05rem; }
  .acct__logo { width: 20px; height: 20px; border-radius: 6px; background: var(--color-tertiary); display: inline-block; }
  .acct__nav { display: flex; flex-direction: column; gap: 2px; }
  .acct__navitem { font-size: var(--size-sm); color: var(--color-secondary); padding: 8px 10px; border-radius: var(--radius-sm); }
  .acct__navitem--active { background-color: rgba(8,102,255,0.08); color: var(--color-tertiary); font-weight: var(--weight-semibold); }

  .acct__main { padding: var(--space-6) var(--space-8); display: flex; flex-direction: column; gap: var(--space-6); }
  .acct__head { display: flex; justify-content: space-between; align-items: center; }
  .acct__id { display: flex; align-items: center; gap: var(--space-4); }
  .acct__avatar { width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, var(--color-tertiary), #7aa7ff); }
  .acct__title { font-size: 1.4rem; font-weight: var(--weight-bold); color: var(--color-primary); margin: 0; }
  .acct__sub { font-size: var(--size-sm); color: var(--color-secondary); margin: 2px 0 0; }
  .acct__btn { font-size: var(--size-sm); font-weight: var(--weight-semibold); color: var(--color-tertiary); border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding: 8px 14px; background: var(--color-surface); }

  .acct__card { background-color: var(--color-neutral); border: 1px solid var(--color-border); border-radius: var(--radius-md, 10px); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .acct__card-title { font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); font-weight: var(--weight-semibold); }
  .acct__fields { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5) var(--space-8); margin: 0; }
  .acct__field { display: flex; flex-direction: column; gap: 4px; }
  .acct__field dt { font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); font-weight: var(--weight-semibold); }
  .acct__field dd { font-size: 1rem; color: var(--color-primary); margin: 0; font-weight: var(--weight-semibold); }

  .acct__plan { display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--color-border); border-radius: var(--radius-md, 10px); padding: var(--space-4) var(--space-6); }
  .acct__plan-name { font-size: 1rem; font-weight: var(--weight-bold); color: var(--color-primary); }
  .acct__plan-meta { font-size: var(--size-sm); color: var(--color-secondary); margin-left: var(--space-3); }
  .acct__plan-pill { font-size: var(--size-label); font-weight: var(--weight-semibold); padding: 3px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: var(--ls-wide); background: rgba(26,157,90,0.12); color: #1a9d5a; }

  /* Censor treatment (mirror the extension) */
  .blur { filter: blur(5px); }
</style>
