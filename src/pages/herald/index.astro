---
import Layout from '../../layouts/Layout.astro';

// Waveform bar heights for the Natural-voices visual.
const bars = [7, 13, 19, 10, 23, 15, 9, 21, 13, 17, 10, 24, 12, 16, 8, 20, 14, 11];
// Heights for the "recording" waveform in the phone's score area — same look as
// the natural-voices bars (varied heights, gentle pulse).
const waveBars = [10, 18, 26, 14, 30, 20, 12, 28, 16, 23, 13, 30, 17, 24, 11, 21];

// A little month calendar for the Progress visual. Each day has a "read level"
// 0-4 (more reading = more pronounced colour), GitHub-heatmap style; days not
// listed are 0 (no reading). The last seven (24-30) all have a level, so they
// read as a seven-day streak.
const dow = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
const levels = { 2: 2, 3: 3, 5: 1, 6: 1, 9: 2, 10: 4, 12: 2, 13: 1, 16: 3, 17: 2, 19: 1, 20: 1, 22: 1, 24: 2, 25: 3, 26: 4, 27: 2, 28: 3, 29: 4, 30: 3 };
const monthOffset = 3; // the 1st falls on a Wednesday
const calCells = [];
for (let i = 0; i < monthOffset; i++) calCells.push(null);
for (let d = 1; d <= 30; d++) calCells.push(d);
while (calCells.length % 7 !== 0) calCells.push(null);
---

<Layout
  title="Herald: Read Aloud and Build a Speaking Habit"
  description="Herald is a read-aloud app that scores your pronunciation, reads pages in a natural voice, and helps you build a daily speaking habit. Coming soon to Google Play."
>
  <div class="herald-page">

    <!-- ===================== HERO + DEMO ===================== -->
    <section class="hero">
      <div class="container hero__grid">

        <div class="hero__text">
          <div class="eyebrow">Android App</div>
          <h1 class="hero__headline">Read aloud.<br /><em>Build the habit.</em></h1>
          <p class="hero__body">
            Read a page out loud, get a gentle score, and keep your streak going.
          </p>
          <span class="btn-soon">Coming soon to Google Play</span>
          <p class="hero__note">Free to download. No account needed to start.</p>
        </div>

        <div class="hero__demo">
          <div class="phone">
            <span class="phone__camera"></span>
            <div class="phone__screen">
              <div class="statusbar">
                <span>9:41</span>
                <span class="statusbar__icons">
                  <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><rect x="2" y="14" width="3" height="6" rx="1"/><rect x="7" y="10" width="3" height="10" rx="1"/><rect x="12" y="6" width="3" height="14" rx="1"/><rect x="17" y="2" width="3" height="18" rx="1"/></svg>
                  <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 4C7.5 4 3.7 5.6 1 8.2l2 2C5.2 8.2 8.4 7 12 7s6.8 1.2 9 3.2l2-2C20.3 5.6 16.5 4 12 4Zm0 6c-2.6 0-5 .9-6.8 2.5l2.1 2.1C8.5 15.6 10.2 15 12 15s3.5.6 4.7 1.6l2.1-2.1C17 10.9 14.6 10 12 10Zm0 6-2.5 2.5L12 21l2.5-2.5L12 16Z"/></svg>
                  <svg viewBox="0 0 26 24" width="20" height="15" fill="none" aria-hidden="true"><rect x="1.5" y="6.5" width="20" height="11" rx="2.5" stroke="currentColor" stroke-width="1.6"/><rect x="3.5" y="8.5" width="14" height="7" rx="1" fill="currentColor"/><rect x="23" y="9.5" width="2" height="5" rx="1" fill="currentColor"/></svg>
                </span>
              </div>

              <div class="screen-track" id="screen-track">

                <!-- HOME SCREEN -->
                <div class="screen screen--home">
                  <div class="home__top">
                    <span class="home__brand">Herald</span>
                    <span class="home__avatar"></span>
                  </div>
                  <div class="home__card">
                    <div class="home__label">Speaking accuracy</div>
                    <div class="home__accrow">
                      <span class="home__acc">97%</span>
                      <span class="home__streak"><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M12 23a7 7 0 0 0 7-7c0-2-1-3.9-2.5-5.4.2 1.2-.6 2.4-1.8 2.6.6-2.6-.9-5.3-3.2-6.8.3 2.2-.9 4.3-2.7 5.6A6.99 6.99 0 0 0 5 16a7 7 0 0 0 7 7Z"/></svg>2 day streak</span>
                    </div>
                    <svg class="home__chart" viewBox="0 0 280 92" aria-hidden="true">
                      <polygon points="8,46 52,54 96,58 140,46 184,42 228,30 272,50 272,92 8,92" fill="rgba(197,106,60,0.10)"/>
                      <polyline points="8,46 52,54 96,58 140,46 184,42 228,30 272,50" fill="none" stroke="#C56A3C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="8" cy="46" r="4" fill="#FBF4E7" stroke="#C56A3C" stroke-width="2.5"/>
                      <circle cx="52" cy="54" r="4" fill="#FBF4E7" stroke="#C56A3C" stroke-width="2.5"/>
                      <circle cx="96" cy="58" r="4" fill="#FBF4E7" stroke="#C56A3C" stroke-width="2.5"/>
                      <circle cx="140" cy="46" r="4" fill="#FBF4E7" stroke="#C56A3C" stroke-width="2.5"/>
                      <circle cx="184" cy="42" r="4" fill="#FBF4E7" stroke="#C56A3C" stroke-width="2.5"/>
                      <circle cx="228" cy="30" r="4" fill="#FBF4E7" stroke="#C56A3C" stroke-width="2.5"/>
                      <circle cx="272" cy="50" r="5" fill="#C56A3C"/>
                    </svg>
