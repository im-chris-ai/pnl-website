---
import Layout from '../layouts/Layout.astro';
import CensorSandbox from '../components/CensorSandbox.astro';

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Click to Censor',
  applicationCategory: 'BrowserApplication',
  operatingSystem: 'Chrome',
  url: 'https://pixanovalabs.com/click-to-censor',
  description:
    'A lightweight Chrome extension that lets you blur, black out, or hide any sensitive element on any webpage in real time, with optional click-to-reveal.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<Layout
  title="Click to Censor: Blur, Blackout, or Hide Elements Instantly"
  description="A lightweight Chrome extension that lets you blur, black out, or hide any sensitive element on any webpage in real time, with optional click-to-reveal."
  jsonLd={appSchema}
>

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__eyebrow label">Browser Extension</div>
      <h1 class="hero__headline display">
        Hide sensitive data<br /><em>in one click</em>.
      </h1>
      <p class="hero__body">
        A privacy-first browser extension for developers and creators. Instantly blur, black out, or hide emails, balances, and images before you share your screen or record.
      </p>
      <div class="hero__actions">
        <a href="#playground" class="btn btn-primary">Try the Sandbox</a>
        <a href="https://chromewebstore.google.com/detail/click-to-censor-elements/fheicolihdhjmcbmpglffgcmicngdclj" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
          Add to Chrome, It's Free
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== INTERACTIVE PLAYGROUND ===================== -->
  <section id="playground" class="playground-section">
    <div class="container">
      <div class="playground__header">
        <div class="label">Live Demonstration</div>
        <h2>Interactive Sandbox</h2>
        <p>
          Hover over any element on the mock dashboard, then click to blur it. Click again to bring it back.
        </p>
      </div>

      <CensorSandbox />
    </div>
  </section>

  <!-- ===================== FEATURES GRID ===================== -->
  <section class="features-section">
    <div class="container">
      <div class="features__header">
        <div class="label">Designed for Privacy</div>
        <h2>Product Capabilities</h2>
      </div>

      <div class="features__grid">
        <div class="feature-card card">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </div>
          <h3>100% Local & Secure</h3>
          <p>No servers, no tracking, no database. Everything runs natively inside your browser.</p>
        </div>

        <div class="feature-card card">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67" />
            </svg>
          </div>
          <h3>Smart Persistence</h3>
          <p>Censored elements are saved by CSS selector, so they stay hidden across page refreshes.</p>
        </div>

        <div class="feature-card card">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
          </div>
          <h3>Three Censor Modes</h3>
          <p>Soft blur, solid blackout, or fully hide an element. Switch modes on the fly.</p>
        </div>

        <div class="feature-card card">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
          </div>
          <h3>Click to Reveal</h3>
          <p>Click a censored element to peek, then hide it again. Your saved censors stay intact.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STEPS ===================== -->
  <section class="steps-section">
    <div class="container">
      <div class="steps__header">
        <div class="label">Quick Start</div>
        <h2>How to Install & Use</h2>
      </div>

      <ol class="steps__list">
        <li class="step-item">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Download Extension</h3>
            <p>Install from the Chrome Web Store in one click. Lightweight and ready instantly, no setup.</p>
          </div>
        </li>
        <li class="step-item">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Activate Censor Mode</h3>
            <p>Click the toolbar icon to start the inspector, then pick a censor mode from the popup.</p>
          </div>
        </li>
        <li class="step-item">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Select & Hide Elements</h3>
            <p>Hover any element (text, image, table) and click once to censor it instantly.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ===================== CTA BANNER ===================== -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <h2>Hide sensitive data today.</h2>
      <p>Get the free Chrome extension and share your screen or record without exposing private info.</p>
      <a href="https://chromewebstore.google.com/detail/click-to-censor-elements/fheicolihdhjmcbmpglffgcmicngdclj" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Add to Chrome, It's Free
      </a>
      <a href="/click-to-censor/privacy" class="cta-banner__privacy">Privacy Policy</a>
    </div>
  </section>

</Layout>


<style>
  /* ===================== HERO ===================== */
  .hero {
    padding-block: var(--space-24) var(--space-16);
    background-color: var(--color-surface);
  }

  .hero__inner {
    max-width: 800px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-4);
  }

  .hero__headline {
    margin-bottom: var(--space-6);
  }

  .hero__body {
    font-size: 1.15rem;
    max-width: 600px;
    margin-bottom: var(--space-8);
    color: var(--color-secondary);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  /* ===================== PLAYGROUND ===================== */
  .playground-section {
    padding-block: var(--space-20);
    background-color: var(--color-neutral);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .playground__header {
    max-width: 640px;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .playground__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-family: var(--font-serif);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
  }

  /* ===================== FEATURES ===================== */
  .features-section {
    padding-block: var(--space-20);
    background-color: var(--color-surface);
  }

  .features__header {
    max-width: 600px;
    margin-bottom: var(--space-12);
  }

  .features__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-family: var(--font-serif);
    color: var(--color-primary);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
  }

  .feature-card {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    background-color: rgba(8, 102, 255, 0.06);
    color: var(--color-tertiary);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-card h3 {
    font-size: 1.1rem;
    font-weight: var(--weight-semibold);
  }

  .feature-card p {
    font-size: var(--size-sm);
    line-height: 1.6;
    margin: 0;
  }

  /* ===================== STEPS ===================== */
  .steps-section {
    padding-block: var(--space-20);
    background-color: var(--color-neutral);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .steps__header {
    max-width: 600px;
    margin-bottom: var(--space-12);
  }

  .steps__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-family: var(--font-serif);
    color: var(--color-primary);
  }

  .steps__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .step-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .step-num {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: var(--weight-bold);
    color: var(--color-tertiary);
    line-height: 1;
  }

  .step-content h3 {
    font-size: 1.1rem;
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .step-content p {
    font-size: var(--size-sm);
    line-height: 1.6;
    margin: 0;
  }

  /* ===================== CTA BANNER ===================== */
  .cta-banner {
    padding-block: var(--space-24);
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    text-align: center;
  }

  .cta-banner__inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-banner h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-on-primary);
  }

  .cta-banner p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
    margin-bottom: var(--space-4);
  }

  .cta-banner__privacy {
    margin-top: var(--space-4);
    font-size: var(--size-sm);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.12s ease;
  }

  .cta-banner__privacy:hover { color: var(--color-on-primary); }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 768px) {
    .hero { padding-block: var(--space-16) var(--space-10); }
    .steps__list { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>
