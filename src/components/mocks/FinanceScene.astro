---
// Mock payments/revenue dashboard for blog screenshots (point: account balances).
// Generic, unbranded. `censor` renders the "after" state (blackout + blur) using the
// same visual treatment the extension applies, for before/after shots.
const { censor = false } = Astro.props;
const txns = [
  { name: 'Acme Corp', email: 'billing@acmecorp.com', amount: '+$2,500.00', date: 'Jun 28' },
  { name: 'Lena Ortiz', email: 'lena.ortiz@gmail.com', amount: '+$149.00', date: 'Jun 28' },
  { name: 'Northwind Ltd', email: 'ap@northwind.io', amount: '+$4,820.00', date: 'Jun 27' },
  { name: 'Marcus Webb', email: 'm.webb@outlook.com', amount: '+$39.00', date: 'Jun 27' },
  { name: 'Bright Labs', email: 'finance@brightlabs.co', amount: '+$1,200.00', date: 'Jun 26' },
];
---

<div class="fin mock">
  <!-- Browser chrome -->
  <div class="fin__bar">
    <div class="fin__dots"><span></span><span></span><span></span></div>
    <div class="fin__url">https://app.ledger-pay.com/dashboard</div>
  </div>

  <div class="fin__app">
    <!-- Sidebar -->
    <aside class="fin__side">
      <div class="fin__brand"><span class="fin__logo"></span> Ledger</div>
      <nav class="fin__nav">
        <span class="fin__navitem fin__navitem--active">Overview</span>
        <span class="fin__navitem">Payments</span>
        <span class="fin__navitem">Customers</span>
        <span class="fin__navitem">Payouts</span>
        <span class="fin__navitem">Settings</span>
      </nav>
    </aside>

    <!-- Main -->
    <main class="fin__main">
      <header class="fin__head">
        <div>
          <h1 class="fin__title">Overview</h1>
          <p class="fin__sub">Last 30 days</p>
        </div>
        <div class="fin__user">
          <span class="fin__avatar"></span>
          <span class="fin__username">Sarah Jenkins</span>
        </div>
      </header>

      <!-- KPI cards -->
      <section class="fin__kpis">
        <div class="fin__kpi">
          <span class="fin__kpi-label">Available balance</span>
          <span class={`fin__kpi-val sens ${censor ? 'blackout' : ''}`}>$48,210.55</span>
        </div>
        <div class="fin__kpi">
          <span class="fin__kpi-label">Revenue this month</span>
          <span class={`fin__kpi-val sens ${censor ? 'blackout' : ''}`}>$127,840</span>
        </div>
        <div class="fin__kpi">
          <span class="fin__kpi-label">MRR</span>
          <span class={`fin__kpi-val sens ${censor ? 'blackout' : ''}`}>$31,200</span>
        </div>
        <div class="fin__kpi">
          <span class="fin__kpi-label">Payouts pending</span>
          <span class="fin__kpi-val">$9,430</span>
        </div>
      </section>

      <!-- Chart -->
      <section class="fin__chart">
        <div class="fin__chart-head">
          <span class="fin__card-title">Revenue</span>
          <span class={`fin__chart-fig sens ${censor ? 'blackout' : ''}`}>$127,840</span>
        </div>
        <svg viewBox="0 0 640 180" preserveAspectRatio="none" class="fin__svg" aria-hidden="true">
          <defs>
            <linearGradient id="finGrad" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="var(--color-tertiary)" stop-opacity="0.28" />
              <stop offset="100%" stop-color="var(--color-tertiary)" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path d="M0,150 C80,140 120,120 180,110 C260,96 300,70 380,60 C460,50 520,30 640,18 L640,180 L0,180 Z" fill="url(#finGrad)" />
          <path d="M0,150 C80,140 120,120 180,110 C260,96 300,70 380,60 C460,50 520,30 640,18" fill="none" stroke="var(--color-tertiary)" stroke-width="2.5" />
        </svg>
      </section>

      <!-- Transactions -->
      <section class="fin__txns">
        <span class="fin__card-title">Recent transactions</span>
        <table class="fin__table">
          <thead>
            <tr><th>Customer</th><th>Email</th><th>Amount</th><th>Date</th></tr>
          </thead>
          <tbody>
            {txns.map((t) => (
              <tr>
                <td class={`sens ${censor ? 'blur' : ''}`}>{t.name}</td>
                <td class={`fin__muted sens ${censor ? 'blur' : ''}`}>{t.email}</td>
                <td class="fin__amt">{t.amount}</td>
                <td class="fin__muted">{t.date}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    </main>
  </div>
</div>

<style>
  .fin {
    font-family: var(--font-sans, system-ui, sans-serif);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(28, 43, 51, 0.10);
    max-width: 980px;
    margin: 0 auto;
  }

  .fin__bar {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background-color: var(--color-neutral);
    border-bottom: 1px solid var(--color-border);
    padding: 12px var(--space-4);
  }
  .fin__dots { display: flex; gap: 6px; }
  .fin__dots span { width: 10px; height: 10px; border-radius: 50%; background-color: rgba(28,43,51,0.15); }
  .fin__url {
    flex-grow: 1; max-width: 460px; margin-inline: auto;
    text-align: center; font-family: monospace; font-size: 0.78rem;
    color: var(--color-secondary); background-color: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding-block: 4px;
  }

  .fin__app { display: grid; grid-template-columns: 200px 1fr; }

  .fin__side {
    background-color: var(--color-neutral);
    border-right: 1px solid var(--color-border);
    padding: var(--space-6) var(--space-4);
    display: flex; flex-direction: column; gap: var(--space-6);
  }
  .fin__brand { display: flex; align-items: center; gap: 8px; font-weight: var(--weight-bold); color: var(--color-primary); font-size: 1.05rem; }
  .fin__logo { width: 20px; height: 20px; border-radius: 6px; background: var(--color-tertiary); display: inline-block; }
  .fin__nav { display: flex; flex-direction: column; gap: 2px; }
  .fin__navitem { font-size: var(--size-sm); color: var(--color-secondary); padding: 8px 10px; border-radius: var(--radius-sm); }
  .fin__navitem--active { background-color: rgba(8,102,255,0.08); color: var(--color-tertiary); font-weight: var(--weight-semibold); }

  .fin__main { padding: var(--space-6) var(--space-8); display: flex; flex-direction: column; gap: var(--space-6); }
  .fin__head { display: flex; justify-content: space-between; align-items: flex-start; }
  .fin__title { font-size: 1.4rem; font-weight: var(--weight-bold); color: var(--color-primary); margin: 0; }
  .fin__sub { font-size: var(--size-sm); color: var(--color-secondary); margin: 2px 0 0; }
  .fin__user { display: flex; align-items: center; gap: 8px; }
  .fin__avatar { width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg, var(--color-tertiary), #7aa7ff); }
  .fin__username { font-size: var(--size-sm); font-weight: var(--weight-semibold); color: var(--color-primary); }

  .fin__kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); }
  .fin__kpi {
    background-color: var(--color-neutral); border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 10px); padding: var(--space-4);
    display: flex; flex-direction: column; gap: 6px;
  }
  .fin__kpi-label { font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); font-weight: var(--weight-semibold); }
  .fin__kpi-val { font-size: 1.45rem; font-weight: var(--weight-bold); color: var(--color-primary); }

  .fin__chart { background-color: var(--color-neutral); border: 1px solid var(--color-border); border-radius: var(--radius-md, 10px); padding: var(--space-4); }
  .fin__chart-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-2); }
  .fin__chart-fig { font-size: 1.1rem; font-weight: var(--weight-bold); color: var(--color-primary); }
  .fin__svg { width: 100%; height: 150px; display: block; }
  .fin__card-title { font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); font-weight: var(--weight-semibold); }

  .fin__txns { display: flex; flex-direction: column; gap: var(--space-3); }
  .fin__table { width: 100%; border-collapse: collapse; }
  .fin__table th { text-align: left; font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); padding: 8px 6px; border-bottom: 1px solid var(--color-border); }
  .fin__table td { font-size: var(--size-sm); color: var(--color-primary); padding: 10px 6px; border-bottom: 1px solid rgba(28,43,51,0.06); }
  .fin__muted { color: var(--color-secondary); }
  .fin__amt { color: #1a9d5a; font-weight: var(--weight-semibold); }

  /* Censor treatments (mirror the extension) */
  .blackout { position: relative; color: transparent !important; background-color: var(--color-primary); border-radius: 4px; }
  .blur { filter: blur(5px); }
</style>
