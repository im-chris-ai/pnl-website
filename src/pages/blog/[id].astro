---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { id: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article class="post">
    <div class="container">

      <header class="post__header">
        <a href="/blog" class="post__back">← BLOG</a>
        <time class="post__date" datetime={entry.data.date}>
          {new Date(entry.data.date).toLocaleDateString('en-US', {
            month: 'long', day: 'numeric', year: 'numeric',
          }).toUpperCase()}
        </time>
        <h1 class="post__title">{entry.data.title}</h1>
      </header>

      {entry.data.image && (
        <div class="post__cover">
          <img src={entry.data.image} alt={entry.data.title} class="post__cover-img" />
        </div>
      )}

      <hr class="divider" />

      <div class="post__body">
        <Content />
      </div>

    </div>
  </article>
</Layout>

<style>
  .post {
    padding-block: var(--space-12) var(--space-24);
    background-color: var(--color-surface);
  }

  /* Center the article column */
  .post > .container {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .post__header {
    width: 100%;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post__back {
    color: var(--color-tertiary);
    font-weight: var(--weight-semibold);
    font-size: var(--size-label);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    transition: opacity 0.12s ease;
    display: inline-block;
    margin-bottom: var(--space-1);
    font-family: var(--font-sans);
  }
  .post__back:hover { opacity: 0.8; }

  .post__date {
    color: var(--color-secondary);
    font-size: var(--size-label);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    font-family: var(--font-sans);
  }

  .post__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.12;
    letter-spacing: var(--ls-display);
    margin-top: var(--space-2);
  }

  .post__cover {
    width: 100%;
    margin-bottom: var(--space-10);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .post__cover-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .post__body {
    width: 100%;
    margin-top: var(--space-8);
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-6);
  }

  /* GLOBAL SELECTORS FOR RENDERED MARKDOWN CONTENT */
  .post__body :global(p) {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-secondary);
    margin-bottom: var(--space-6);
  }

  .post__body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    line-height: 1.25;
  }

  .post__body :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .post__body :global(h4) {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .post__body :global(a) {
    color: var(--color-tertiary);
    text-decoration: underline;
  }

  .post__body :global(code) {
    font-size: 0.88em;
    background: var(--color-neutral);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  /* Lists */
  .post__body :global(ul), .post__body :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-8) !important;
    color: var(--color-secondary);
  }
  .post__body :global(ul) { list-style-type: disc !important; }
  .post__body :global(ol) { list-style-type: decimal !important; }
  .post__body :global(li) {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-secondary);
    margin-bottom: var(--space-2);
  }

  /* Blockquotes */
  .post__body :global(blockquote) {
    border: none !important;
    border-top: 1px solid var(--color-border) !important;
    border-bottom: 1px solid var(--color-border) !important;
    padding: var(--space-6) 0 !important;
    margin: var(--space-10) 0 !important;
    text-align: center !important;
  }
  .post__body :global(blockquote p) {
    font-size: 1.15rem !important;
    line-height: 1.6 !important;
    color: var(--color-primary) !important;
    font-style: italic !important;
    margin-bottom: 0 !important;
  }

  /* Tables */
  .post__body :global(table) {
    width: 100% !important;
    border-collapse: collapse !important;
    margin: var(--space-10) 0 !important;
    font-size: 0.95rem !important;
    border-top: 1px solid var(--color-border) !important;
    border-bottom: 1px solid var(--color-border) !important;
  }
  .post__body :global(th), .post__body :global(td) {
    padding: var(--space-3) var(--space-4) !important;
    text-align: left !important;
  }
  .post__body :global(th) {
    border-bottom: 1px solid var(--color-border) !important;
    font-weight: 700 !important;
    color: var(--color-primary) !important;
  }
  .post__body :global(td) {
    color: var(--color-secondary) !important;
  }

  /* Media & Captions */
  .post__body :global(img) {
    width: 100% !important;
    height: auto !important;
    border-radius: var(--radius-md) !important;
    border: 1px solid var(--color-border) !important;
    margin-top: var(--space-6) !important;
  }
  .post__body :global(figcaption) {
    font-size: 0.85rem !important;
    color: var(--color-secondary) !important;
    display: block !important;
    margin-top: var(--space-3) !important;
    margin-bottom: var(--space-6) !important;
    text-align: center !important;
    font-style: italic !important;
  }

  .post__body :global(.video-container) {
    margin-top: var(--space-6) !important;
    border-radius: var(--radius-md) !important;
    overflow: hidden !important;
    border: 1px solid var(--color-border) !important;
  }
  .post__body :global(.video-container video) {
    display: block !important;
    width: 100% !important;
    height: auto !important;
  }
</style>
