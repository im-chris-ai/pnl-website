---
// Mock "you're sharing this window" frame for the Zoom post (point: sharing the RIGHT
// window still exposes the data on it). Generic, unbranded. The green outline + pill mirror
// the on-screen "you are sharing" indicator. `censor` renders the after state (blackout + blur).
const { censor = false } = Astro.props;
const rows = [
  { name: 'Acme Corp',    email: 'billing@acmecorp.com', amount: '+$2,500.00' },
  { name: 'Lena Ortiz',   email: 'lena.ortiz@gmail.com', amount: '+$149.00' },
  { name: 'Northwind Ltd', email: 'ap@northwind.io',     amount: '+$4,820.00' },
];
---

<div class="shf mock">
  <div class="shf__pill"><span class="shf__dot"></span> You're sharing this window</div>

  <div class="shf__frame">
    <div class="shf__bar">
      <div class="shf__dots"><span></span><span></span><span></span></div>
      <div class="shf__url">https://app.ledger-pay.com/dashboard</div>
    </div>

    <div class="shf__body">
      <header class="shf__head">
        <h1 class="shf__title">Overview</h1>
        <span class="shf__pillsm">Last 30 days</span>
      </header>

      <div class="shf__kpis">
        <div class="shf__kpi">
          <span class="shf__kpi-label">Available balance</span>
          <span class={`shf__kpi-val sens ${censor ? 'blackout' : ''}`}>$48,210.55</span>
        </div>
        <div class="shf__kpi">
          <span class="shf__kpi-label">Revenue this month</span>
          <span class={`shf__kpi-val sens ${censor ? 'blackout' : ''}`}>$127,840</span>
        </div>
      </div>

      <table class="shf__table">
        <thead><tr><th>Customer</th><th>Email</th><th>Amount</th></tr></thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class={`sens ${censor ? 'blur' : ''}`}>{r.name}</td>
              <td class={`shf__muted sens ${censor ? 'blur' : ''}`}>{r.email}</td>
              <td class="shf__amt">{r.amount}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .shf { font-family: var(--font-sans, system-ui, sans-serif); max-width: 760px; margin: 0 auto; padding-top: 14px; }

  .shf__pill {
    width: max-content; margin: 0 auto -8px; position: relative; z-index: 2;
    display: flex; align-items: center; gap: 8px;
    background: #137a3f; color: #fff; font-size: var(--size-sm); font-weight: var(--weight-semibold);
    padding: 6px 14px; border-radius: 999px; box-shadow: 0 4px 14px rgba(19,122,63,0.35);
  }
  .shf__dot { width: 8px; height: 8px; border-radius: 50%; background: #7CFFB0; box-shadow: 0 0 0 3px rgba(124,255,176,0.35); }

  .shf__frame {
    border: 3px solid #1aa15a; border-radius: var(--radius-lg);
    background-color: var(--color-surface); overflow: hidden;
    box-shadow: 0 0 0 4px rgba(26,161,90,0.18), 0 12px 40px rgba(28,43,51,0.12);
  }

  .shf__bar { display: flex; align-items: center; gap: var(--space-4); background-color: var(--color-neutral); border-bottom: 1px solid var(--color-border); padding: 10px var(--space-4); }
  .shf__dots { display: flex; gap: 6px; }
  .shf__dots span { width: 10px; height: 10px; border-radius: 50%; background-color: rgba(28,43,51,0.15); }
  .shf__url { flex-grow: 1; max-width: 420px; margin-inline: auto; text-align: center; font-family: monospace; font-size: 0.76rem; color: var(--color-secondary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding-block: 4px; }

  .shf__body { padding: var(--space-6) var(--space-6); display: flex; flex-direction: column; gap: var(--space-5); }
  .shf__head { display: flex; align-items: center; gap: var(--space-3); }
  .shf__title { font-size: 1.3rem; font-weight: var(--weight-bold); color: var(--color-primary); margin: 0; }
  .shf__pillsm { font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); background: var(--color-neutral); border: 1px solid var(--color-border); padding: 3px 9px; border-radius: 999px; }

  .shf__kpis { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); }
  .shf__kpi { background-color: var(--color-neutral); border: 1px solid var(--color-border); border-radius: var(--radius-md, 10px); padding: var(--space-4); display: flex; flex-direction: column; gap: 6px; }
  .shf__kpi-label { font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); font-weight: var(--weight-semibold); }
  .shf__kpi-val { font-size: 1.45rem; font-weight: var(--weight-bold); color: var(--color-primary); width: max-content; }

  .shf__table { width: 100%; border-collapse: collapse; }
  .shf__table th { text-align: left; font-size: var(--size-label); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-secondary); padding: 8px 6px; border-bottom: 1px solid var(--color-border); }
  .shf__table td { font-size: var(--size-sm); color: var(--color-primary); padding: 10px 6px; border-bottom: 1px solid rgba(28,43,51,0.06); width: max-content; }
  .shf__muted { color: var(--color-secondary); }
  .shf__amt { color: #1a9d5a; font-weight: var(--weight-semibold); }

  /* Censor treatments (mirror the extension) */
  .blackout { position: relative; color: transparent !important; background-color: var(--color-primary); border-radius: 4px; }
  .blur { filter: blur(5px); }
</style>
